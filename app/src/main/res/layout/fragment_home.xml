<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".Fragment.HomeFragment"
    android:background="#F5F7FA">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="10"
                android:layout_marginHorizontal="16dp">
                <LinearLayout
                    android:layout_weight="8"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Good Morning,"
                        android:textSize="18sp"
                        android:textColor="#8A9BB0"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Neha 👋 "
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"
                        android:textSize="30sp"/>
                </LinearLayout>
                <ImageView
                    android:layout_weight="2"
                    android:layout_height="45dp"
                    android:layout_width="5dp"
                    android:src="@drawable/ic_notifications"
                    android:background="@drawable/bg_white"
                    android:elevation="0dp"
                    android:padding="5dp"
                    android:layout_gravity="center"
                    android:layout_marginVertical="5dp"
                    android:layout_marginRight="7dp"/>
                <TextView
                    android:layout_weight="2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NV"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_green"
                    android:textColor="@color/white"
                    android:padding="10dp"
                    android:layout_gravity="center"/>
            </LinearLayout>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:background="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="5dp"
                    android:background="@color/white">

                    <!-- Left Side: Circular Streak -->
                    <FrameLayout
                        android:layout_width="130dp"
                        android:layout_height="130dp">

                       <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/circularStreak"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:indeterminate="false"
                            app:indicatorSize="120dp"
                            app:trackThickness="9dp"
                            android:max="30"
                            android:progress="14"
                            app:indicatorColor="@color/blue"
                            app:trackColor="#F0F0F0"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:text="🔥"
                                android:textSize="18sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"/>
                            <TextView android:text="14"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#212121"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"/>
                            <TextView android:text="days"
                                android:textSize="12sp"
                                android:textColor="#8A9BB0"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- Right Side: Text & Progress Bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical"
                        android:layout_gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Learning Streak 🔥"
                            android:textColor="#212121"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:layout_marginBottom="3dp"/>

                        <TextView
                            android:id="@+id/tvGoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14/30 day goal"
                            android:textColor="#757575"/>

                        <ProgressBar
                            android:id="@+id/horizontalProgress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="8dp"
                            android:progress="45" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="16 days to reach your goal"
                            android:textSize="12sp"
                            android:textColor="#757575"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:weightSum="10">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_trophy"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top Contributors"
                    android:textColor="#0D1B2A"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_weight="7"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="#3B82F6"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="end"
                    android:layout_weight="2"/>

            </LinearLayout>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp"
                    android:layout_marginTop="5dp">

                    <!-- Rank 1 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="12"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_1st_winner"
                            android:layout_weight="2"/>
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="AM"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_green"
                            android:textColor="@color/white"
                            android:padding="10dp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_weight="7"
                            android:layout_marginLeft="7dp">
                            <TextView
                                android:id="@+id/topper1Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Neha Vaghela"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/topper1Points"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Computer Engineering "
                                android:textColor="#8A9BB0"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="10dp"
                                android:layout_margin="2dp"
                                app:strokeColor="#FFD700"
                                app:strokeWidth="1dp">
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:paddingVertical="4dp"
                                    android:paddingHorizontal="5dp">
                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:src="@drawable/ic_star" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="310 pts"
                                        android:textColor="#FFD700"/>
                                </LinearLayout>

                            </com.google.android.material.card.MaterialCardView>
                                <com.google.android.material.button.MaterialButton
                                    android:layout_width="85dp"
                                    android:layout_height="40dp"
                                    android:text="Follow"
                                    android:textSize="12sp"
                                    android:textColor="@color/white"
                                    android:backgroundTint="@color/blue"
                                    app:strokeColor="#DADADA"
                                    app:strokeWidth="1dp"
                                    app:cornerRadius="10dp"/>

                        </LinearLayout>


                    </LinearLayout>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#EEEEEE"/>
                    <!-- Rank 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="12"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_2nd_winner"
                            android:layout_weight="2"/>
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="AM"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_green"
                            android:textColor="@color/white"
                            android:padding="10dp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_weight="7"
                            android:layout_marginLeft="7dp">
                            <TextView
                                android:id="@+id/topper1Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rahul Sharma"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/topper1Points"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Information Technology "
                                android:textColor="#8A9BB0"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end"
                            android:layout_marginTop="3dp">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="10dp"
                                android:layout_margin="2dp"
                                app:strokeColor="#C0C0C0"
                                app:strokeWidth="1dp">
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:paddingVertical="4dp"
                                    android:paddingHorizontal="5dp">
                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:src="@drawable/ic_star_2" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="240 pts"
                                        android:textColor="#C0C0C0"/>
                                </LinearLayout>

                            </com.google.android.material.card.MaterialCardView>
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="85dp"
                                android:layout_height="40dp"
                                android:text="Follow"
                                android:textSize="12sp"
                                android:textColor="@color/white"
                                android:backgroundTint="@color/blue"
                                app:strokeColor="#DADADA"
                                app:strokeWidth="1dp"
                                app:cornerRadius="10dp"/>

                        </LinearLayout>


                    </LinearLayout>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#EEEEEE"/>

                    <!-- Rank 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="12"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_3rd_winner"
                            android:layout_weight="2"/>
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="AM"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_green"
                            android:textColor="@color/white"
                            android:padding="10dp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_weight="7"
                            android:layout_marginLeft="7dp">
                            <TextView
                                android:id="@+id/topper1Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Arjun Mehta"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/topper1Points"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mechanical Engineering "
                                android:textColor="#8A9BB0"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end"
                            android:layout_marginTop="3dp">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="10dp"
                                android:layout_margin="2dp"
                                app:strokeColor="#CD7F32"
                                app:strokeWidth="1dp">
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:paddingVertical="4dp"
                                    android:paddingHorizontal="5dp">
                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:src="@drawable/ic_star_3" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="160 pts"
                                        android:textColor="#CD7F32"/>
                                </LinearLayout>

                            </com.google.android.material.card.MaterialCardView>
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="85dp"
                                android:layout_height="40dp"
                                android:text="Follow"
                                android:textSize="12sp"
                                android:textColor="@color/white"
                                android:backgroundTint="@color/blue"
                                app:strokeColor="#DADADA"
                                app:strokeWidth="1dp"
                                app:cornerRadius="10dp"/>

                        </LinearLayout>


                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What Students Say"
                    android:textColor="#0D1B2A"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_weight="7"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Feedback from our community"
                    android:textColor="#8A9BB0"
                    android:textSize="14sp"
                    android:layout_weight="7"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>


</RelativeLayout>