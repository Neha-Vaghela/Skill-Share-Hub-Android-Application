<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".FunctionalFragment.ShareResourceFragment">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginRight="7dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_back"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share Resource"
                    android:textColor="#0D1B2A"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_weight="7"
                    android:layout_marginTop="7dp"
                    android:layout_marginLeft="5dp"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resource type *"
                android:textSize="16sp"
                android:textColor="#4A5568"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="10"
                android:padding="5dp">

                <LinearLayout
                    android:id="@+id/youtube"
                    android:layout_weight="5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_white"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="15dp"
                    android:gravity="center"
                    android:elevation="2dp"
                    android:layout_margin="5dp">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_youtube"/>
                    <TextView
                        android:id="@+id/youtubeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Youtube video"
                        android:textSize="16sp"
                        android:textColor="#4A5568"
                        android:textStyle="bold"
                        android:layout_marginLeft="7dp"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/pdf"
                    android:layout_weight="5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_white"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="15dp"
                    android:gravity="center"
                    android:layout_margin="5dp"
                    android:elevation="2dp">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_pdf"/>
                    <TextView
                        android:id="@+id/pdfText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PDF Notes"
                        android:textSize="16sp"
                        android:textColor="#4A5568"
                        android:textStyle="bold"
                        android:layout_marginLeft="7dp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="10"
                android:padding="5dp">

                <LinearLayout
                    android:id="@+id/github"
                    android:layout_weight="5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_white"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="15dp"
                    android:gravity="center"
                    android:elevation="2dp"
                    android:layout_margin="5dp">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="29dp"
                        android:src="@drawable/ic_github" />
                    <TextView
                        android:id="@+id/githubText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Github/Code"
                        android:textSize="16sp"
                        android:textColor="#4A5568"
                        android:textStyle="bold"
                        android:layout_marginLeft="7dp"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/ResouceLink"
                    android:layout_weight="5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_white"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="15dp"
                    android:gravity="center"
                    android:layout_margin="5dp"
                    android:elevation="2dp">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_link" />
                    <TextView
                        android:id="@+id/ResourceeLinkText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Link/Resource"
                        android:textSize="16sp"
                        android:textColor="#4A5568"
                        android:textStyle="bold"
                        android:layout_marginLeft="7dp"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title *"
                android:textSize="16sp"
                android:textColor="#4A5568"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>
            <EditText
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_white"
                android:gravity="top|start"
                android:hint="e.g. DSA Complete Notes - Semester 4"
                android:inputType="textMultiLine"
                android:maxLines="2"
                android:padding="16dp"
                android:layout_marginTop="10dp"
                android:elevation="1dp"
                android:layout_marginHorizontal="5dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="16sp"
                android:textColor="#4A5568"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>
            <EditText
                android:id="@+id/txtDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_white"
                android:gravity="top|start"
                android:hint="What does this resource cover? Who is it for?"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:padding="16dp"
                android:layout_marginTop="10dp"
                android:elevation="1dp"
                android:layout_marginHorizontal="5dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="URL/Link *"
                android:textSize="16sp"
                android:textColor="#4A5568"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>
            <EditText
                android:id="@+id/link"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_white"
                android:gravity="top|start"
                android:hint="Link"
                android:inputType="textMultiLine"
                android:maxLines="2"
                android:padding="16dp"
                android:layout_marginTop="10dp"
                android:elevation="1dp"
                android:layout_marginHorizontal="5dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subject *"
                android:textSize="16sp"
                android:textColor="#4A5568"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/resouceCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:clipToPadding="false"
                android:layout_marginTop="20dp"/>
            <TextView
                android:id="@+id/subject"
                android:text="Android"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_white"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:maxLines="2"
                android:padding="16dp"
                android:layout_marginTop="10dp"
                android:elevation="1dp"
                android:layout_marginHorizontal="5dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/submitResource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:text="Share Resource"
                android:textColor="@color/button_text_selector"
                android:backgroundTint="@color/button_bg_selector"
                app:cornerRadius="15dp"
                android:textSize="18sp"
                android:paddingVertical="15dp"
                android:layout_marginTop="20dp"
                app:icon="@drawable/ic_upload"
                app:iconGravity="textStart"
                app:iconTint="@color/white"
                android:layout_marginBottom="70dp">

            </com.google.android.material.button.MaterialButton>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>



</RelativeLayout>